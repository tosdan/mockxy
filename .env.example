# Port listened to by the Mockxy process.
PORT=3000

# Network interface the server binds to. Default: 127.0.0.1 (loopback only) — the admin API
# writes files and executes code, so exposing it on a network must be an explicit choice.
# Set 0.0.0.0 to listen on every interface (like `ng serve --host 0.0.0.0`).
# Docker images set HOST=0.0.0.0 themselves: a container's loopback is unreachable from
# the port mapping, so exposure is decided at the host level instead.
# HOST=0.0.0.0

# Host ports mapped by docker-compose: engine container and dev UI container (ng serve).
# Only read by docker-compose — irrelevant when running `node index.js` directly.
MOCKXY_HOST_PORT=3000
MOCKXY_UI_HOST_PORT=4207

# Base URL of the upstream backend. Optional: leave it unset to run mock-only.
# It is only needed to proxy requests to the backend (proxy fallback or proxy middleware);
# requests that need the backend return 501 Backend Not Configured when it is unset.
BACKEND_URL=http://host.docker.internal:8080

# Timeout in milliseconds for proxied requests (up to the first response headers: started
# streams have no inactivity timeout) and for the execution of local handlers and proxy
# middleware.
REQUEST_TIMEOUT_MS=15000

# Minimum log level emitted by the server logger: error, warn, info or debug.
LOG_LEVEL=info

# Environment. `production` disables mock watch mode and turns the admin API off by default.
# NODE_ENV=production

# Enables automatic mock reload in development; production disables watch mode.
DEV_WATCH=true

# Makes the mock watcher poll the filesystem instead of relying on native events. Needed where
# native events do not arrive: Docker bind mounts, network folders. Default: native events.
# CHOKIDAR_USEPOLLING=true

# Relative or absolute path to the folder that contains the mock definitions.
# In this repo it points at the demo workspace (see workspace/).
MOCKS_DIR=workspace/mocks

# Relative or absolute path to the folder with the JSON data files that handlers and proxy
# middleware can read via the data() context accessor (Dati page). Versioned like mocks.
FILES_DIR=workspace/files

# Enables the admin API used to inspect and manage mocks from the UI. Default: true in
# development, false in production (NODE_ENV). It has no authentication, writes files and runs
# JavaScript: keep it off on servers reachable by others (see the security section in README).
ADMIN_API_ENABLED=true

# Extra hostnames accepted by the admin API's Host-header check (DNS rebinding guard), on top
# of the loopback names (localhost, 127.0.0.1, ::1). Comma separated, no port. Examples: a
# /etc/hosts alias on your machine, or the server name when hardening an intranet deployment
# (setting this also enables the check on non-loopback binds).
# ADMIN_ALLOWED_HOSTS=mockxy.local,mockxy.intranet

# Absolute or relative path to the compiled admin UI (Angular build output). When set, the
# server serves it under /_admin/ui. Used by the Electron desktop app; leave unset on the
# headless server, where the admin UI is not served.
# UI_DIST_DIR=mockxy-ui/dist/mockxy-ui/browser

# Proxies non-mocked requests to BACKEND_URL instead of returning a mock-only 404.
PROXY_FALLBACK_ENABLED=true

# Automatic list filters (?key=value on array/list mock bodies) compare values ignoring letter
# case when true (default); set false for exact, case-sensitive matching. In the desktop app this
# is a per-workspace setting in the workspace settings dialog.
CASE_INSENSITIVE_FILTERS=true

# Automatic CORS handling, off by default: the recommended flow (frontend dev-server proxy,
# same-origin UI, non-browser clients) never needs it. Enable it only when a browser frontend on
# another origin calls this server directly (e.g. exposed on the LAN): the engine then answers
# preflight OPTIONS requests (an explicit OPTIONS mock takes precedence) and sets the CORS
# headers — echoing the request origin, credentials allowed — on EVERY response it serves,
# overriding both CORS headers stored inside mocks (captured from the original backend) and
# those of proxied responses: a shared backend's policy may not allow your origin, and with
# Mockxy in between it is Mockxy's policy that must apply. Leave it off to observe the real
# backend policy or to manage CORS headers manually in mocks — then nothing is touched. In the
# desktop app this is a per-workspace setting in the workspace settings dialog.
CORS_ENABLED=false

# Adapts Set-Cookie headers forwarded from the proxied backend, on by default: removes the
# Domain attribute (the browser talks to Mockxy, so a cookie pinned to the backend's domain
# would be silently rejected and the session never established), plus Secure and SameSite=None
# (rejected over plain http). Cookie name/value and the other attributes pass untouched. Turn
# it off to observe the backend's original Set-Cookie headers, or if you share cookies across
# subdomains through a DNS alias pointing at Mockxy. In the desktop app this is a per-workspace
# setting in the workspace settings dialog.
ADAPT_PROXY_COOKIES=true

# Rewrites Location headers of proxied redirects that point at BACKEND_URL's origin, replacing
# it with the address the client used to reach Mockxy (path and query preserved): an absolute
# redirect to the backend would take the browser out of Mockxy, losing proxy, adapted cookies
# and CORS policy (typical of login flows and trailing-slash redirects). Relative redirects and
# redirects to third-party hosts (external SSO, CDNs) always pass untouched. In the desktop app
# this is a per-workspace setting in the workspace settings dialog.
REWRITE_PROXY_REDIRECTS=true

# Simulated latency. NOTE: these two are only read by docker-compose, which maps them onto the
# npm launch flags — the engine itself does not read them. When running directly, use the CLI
# flags instead: `node index.js --delay=500 --delay-all` (or `npm run dev:backend -- --delay=500`).
# MOCKXY_DELAY: global delay in ms applied to mocks without their own delayMs; 0 = none.
# MOCKXY_DELAY_ALL: apply the same delay to proxied requests too.
MOCKXY_DELAY=0
MOCKXY_DELAY_ALL=false

# Monitor "dump on disk": directory (relative or absolute) where captured traffic is persisted as
# append-only NDJSON, beyond the 250 kept in RAM. Gitignored; consumed by the "Storico dump" UI page.
# In this repo it lives inside the demo workspace's local service folder.
MONITOR_DUMP_DIR=workspace/.mockxy/monitor-dump

# Dump flush cadence and batch size (flush on whichever comes first) and per-file rotation size in bytes.
MONITOR_DUMP_INTERVAL_MS=30000
MONITOR_DUMP_THRESHOLD=100
MONITOR_DUMP_MAX_FILE_BYTES=52428800

# Cap on the total size of the dump folder: when exceeded, the oldest dump files are deleted
# (never the file currently being written). Set to 0 to disable pruning entirely.
MONITOR_DUMP_MAX_TOTAL_BYTES=1073741824
